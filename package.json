{
    "name":  "film-processor",
    "version":  "1.1.0",
    "description":  "Professional Film Processor - Desktop Edition",
    "main":  "electron-main.js",
    "scripts":  {
                    "start":  "electron .",
                    "dev":  "electron . --dev",
                    "build":  "electron-builder",
                    "build:win":  "electron-builder --win"
                },
    "author":  "",
    "license":  "MIT",
    "devDependencies":  {
                            "electron":  "^28.0.0",
                            "electron-builder":  "^24.9.1"
                        },
    "dependencies":  {
                         "electron-store":  "^8.1.0"
                     },
    "build":  {
                  "appId":  "com.filmprocessor.app",
                  "productName":  "Film Processor",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "electron-main.js",
                                "preload.js",
                                "package.json",
                                "static/**/*",
                                "templates/**/*",
                                "src/**/*",
                                "pyproject.toml",
                                "!src/__pycache__",
                                "!**/*.pyc",
                                "!**/node_modules"
                            ],
                  "win":  {
                              "target":  "portable",
                              "icon":  "icon.ico",
                              "sign":  false
                          },
                  "portable":  {
                                   "artifactName":  "FilmProcessor-Portable.exe"
                               },
                  "electronDist":  "node_modules/electron/dist"
              }
}